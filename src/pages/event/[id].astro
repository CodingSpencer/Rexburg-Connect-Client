---
import Layout from "../../layouts/Layout.astro";
import EventReviews from "../../components/EventReviews.svelte";
import EventAverageRating from "../../components/EventAverageRating.svelte";
import { events } from "../../data/events";

export function getStaticPaths() {
  return events.map((event) => ({
    params: { id: event.id }
  }));
}

const { id } = Astro.params;
const selectedEvent =
  events.find((event) => event.id === id) || events[0];
---

<Layout>
  <section class="event-detail-page">
    <a href="/" class="back-link">← Back to events</a>

    <article class="event-detail-card">
      <img
        src={selectedEvent.image}
        alt={selectedEvent.title}
        class="event-detail-image"
      />

      <div class="event-detail-content">
        <div class="event-detail-header">
          <div>
            <h1>{selectedEvent.title}</h1>

            <EventAverageRating
                client:load
                eventId={selectedEvent.mongoId}
                fallbackRating={selectedEvent.averageRating}
                showReviewCount={true}
              />
          </div>
        </div>

        <p class="event-long-description">
          {selectedEvent.longDescription}
        </p>

        <div class="event-detail-info">
          <span>📅 {selectedEvent.date}</span>
          <span>📍 {selectedEvent.location}</span>
        </div>
      </div>
    </article>

    <section class="gallery-section">
      <h2>Event Photos</h2>

      <div class="gallery-grid">
        {selectedEvent.gallery.map((photo) => (
          <img
            src={photo}
            alt={`${selectedEvent.title} event`}
          />
        ))}
      </div>
    </section>

    {
      selectedEvent.mongoId ? (
        <EventReviews
          client:load
          eventId={selectedEvent.mongoId}
        />
      ) : (
        <section class="reviews-unavailable">
          <h2>Reviews</h2>
          <p>
            Reviews are not available for this event yet.
          </p>
        </section>
      )
    }
  </section>
</Layout>