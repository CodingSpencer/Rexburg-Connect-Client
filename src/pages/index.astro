---
import Layout from "../layouts/Layout.astro";
import EventCard from "../components/EventCard.svelte";
import { events } from "../data/events";
---

<Layout>
  <section class="home-hero">
    <div class="hero-content">
      <img src="/images/rexy-con.png" alt="Rexburg Connect" class="hero-image" />

      <p class="eyebrow">Upcoming Events • Reviews • Free Activities</p>

      <h1>Discover what’s happening around Rexburg.</h1>

      <p class="hero-text">
        Find fun events, read student feedback, and choose what sounds worth going to.
      </p>

      <div class="search-section">
        <input 
          id="event-search" 
          type="text" 
          placeholder="Search for an event..." 
        />
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="section-heading">
      <h2>Events</h2>
      <a href="/event">View all</a>
    </div>

    <div class="event-grid">
      {events.map((event) => (
        <EventCard event={event} />
      ))}
    </div>
  </section>
</Layout>