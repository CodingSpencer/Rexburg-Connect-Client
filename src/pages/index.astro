---
import Layout from "../layouts/Layout.astro";
import EventCard from "../components/EventCard.svelte";

const sampleEvent = {
  id: "1",
  title: "Country Dancing",
  description: "A fun BYU-I event where students can dance, meet people, and hang out.",
  location: "BYU-I Center",
  date: "Friday night",
  image: "https://placehold.co/600x400",
  averageRating: 4
