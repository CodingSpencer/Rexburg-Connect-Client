---
import Header from "../components/Header.svelte";
import Footer from "../components/Footer.svelte";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Rexburg Connect</title>
  </head>

  <body>
    <Header client:load />

    <div class="page">
      <main>
        <slot />
      </main>
    </div>

    <Footer />
  </body>
</html>

<style>
  html,
  body {
    min-height: 100%;
    margin: 0;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }
</style>
